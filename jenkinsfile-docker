pipeline {
    agent any

    stages {

        stage('Clone Repository') {
            steps {
                echo 'Cloning project from GitHub...'
                git branch: 'main', url: 'https://github.com/Harshit-HM/myproject.git'
            }
        }

        stage('Clean Old Containers & Images') {
            steps {
                echo 'Cleaning old Docker containers and dangling images...'
                sh '''
                docker ps -a -q --filter "name=mysite" | xargs -r docker rm -f
                docker images -q harshitp098/mysite | xargs -r docker rmi -f
                '''
            }
        }
        
        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image...'
                sh '''
                docker build -t harshitp098/mysite .
                docker push harshitp098/mysite
                '''
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying Docker container...'
                sh '''
                docker run -d -p 81:80 --name mysite harshitp098/mysite
                '''
            }
        }

    }

    post {
        always {
            echo 'Pipeline execution completed!'
            sh '''
            docker ps -a
            docker images
            '''
        }
    }
}
